{
  "name": "websocket-chess",
  "version": "1.0.0",
  "author": "Daniel Gustavo Favero",
  "license": "ISC",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^2.8.1"
  },
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "build:server": "turbo run build --filter=server",
    "build:shared": "turbo run build --filter=@websocket-chess/shared",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:server": "turbo run dev --filter=server",
    "start": "turbo run start",
    "start:web": "turbo run start --filter=web",
    "start:server": "turbo run start --filter=server",
    "lint": "turbo run lint",
    "lint:web": "turbo run lint --filter=web",
    "lint:server": "turbo run lint --filter=server",
    "test:server": "turbo run test --filter=server"
  },
  "packageManager": "npm@10.9.4"
}
