{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",

        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
    
        "outDir": "./dist",
        "rootDir": "./src",

        "baseUrl": "./src",
        "paths": {
            "@config/*": ["config/*"],
            "@game/*": ["game/*"],
            "@interfaces/*": ["interfaces/*"],
            "@websocket/*": ["websocket/*"],
            "@orchestrators/*": ["orchestrators/*"],
            "@handlers/*": ["handlers/*"],
            "@types/*": ["@types/*"]
        },
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}