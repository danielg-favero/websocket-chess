{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",

        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "declaration": true,
    
        "outDir": "./dist",
        "rootDir": "./src",

        "baseUrl": "./src",
        "paths": {
            "@config/*": ["config/*"],
            "@interfaces/*": ["interfaces/*"],
            "@lib/*": ["lib/*"],
        },
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}